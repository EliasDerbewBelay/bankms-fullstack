# ── Production (Vercel + Railway/Render) ───────────────────────
# Recommended: proxy API through Next.js rewrites (same-origin, no CORS issues)
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_URL=https://your-api.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=CoreBank MS

# ── Alternative: direct API calls (requires backend CORS_ORIGIN to match) ──
# NEXT_PUBLIC_API_URL=https://your-api.railway.app/api/v1
# BACKEND_URL=https://your-api.railway.app

# ── Local development ──────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# BACKEND_URL=http://localhost:4000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
