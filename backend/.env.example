# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── Database (Neon PostgreSQL) ──────────────────────────────────
# Pooled connection — use the "-pooler" hostname from Neon dashboard
# Append &connect_timeout=30 for Render/Neon cold starts
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
# Direct connection — same endpoint without "-pooler" (required for db:push / preDeployCommand)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

# ── Redis (optional — not used by the app today) ────────────────
# REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated — NO quotes in Render dashboard
CORS_ORIGIN=https://bankms-fullstack.vercel.app,http://localhost:3000
# Allow Vercel preview deployments (*.vercel.app) in addition to the list above
CORS_ALLOW_VERCEL_PREVIEWS=true

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_TRANSFER_MAX=20
RATE_LIMIT_GLOBAL_MAX=100

# ── Logging ─────────────────────────────────────────────────────
# Use "info" in production
LOG_LEVEL=debug
