# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── Database (Neon PostgreSQL) ──────────────────────────────────
# Pooled connection — use the "-pooler" hostname from Neon dashboard
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30
# Direct connection — same endpoint without "-pooler" (required for Prisma migrate/push)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated frontend URLs allowed to call the API directly
CORS_ORIGIN=http://localhost:3000
# Set to true when deploying frontend on Vercel (allows *.vercel.app previews)
CORS_ALLOW_VERCEL_PREVIEWS=false

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_TRANSFER_MAX=20
RATE_LIMIT_GLOBAL_MAX=100

# ── Logging ─────────────────────────────────────────────────────
# Use "info" in production
LOG_LEVEL=debug
